# ── Database ──
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/fhss
SPRING_DATASOURCE_USERNAME=fhss
SPRING_DATASOURCE_PASSWORD=change_me_in_production

# ── Spring Profile ──
SPRING_PROFILES_ACTIVE=docker

# ── ML Service ──
ML_SERVICE_URL=http://ml-service:8000

# ── Redis ──
REDIS_HOST=redis
REDIS_PORT=6379

# ── JWT (prototype only — rotate before production) ──
APP_JWT_SECRET=change-this-secret-in-production-minimum-32-chars!!

# ── CORS ──
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Frontend (Vite dev) ──
VITE_API_PROXY_TARGET=http://localhost:8080
VITE_DEV_PORT=5173

# ── Production Docker (deploy with docker-compose.prod.yml) ──
# GHCR_NAMESPACE=your-org
# IMAGE_TAG=latest
# FRONTEND_PORT=3000
# GATEWAY_PORT=8080
# TL_TIMEOUT_DURATION=6s
