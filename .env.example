# ── Database ──
# PostgreSQL connection (used by backend Docker container)
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/fhss
SPRING_DATASOURCE_USERNAME=fhss
SPRING_DATASOURCE_PASSWORD=change_me_in_production

# ── Spring Profile ──
SPRING_PROFILES_ACTIVE=docker

# ── ML Service ──
# When ML runs in Docker: http://ml-service:8000
# When ML runs locally:  http://host.docker.internal:8000
ML_SERVICE_URL=http://ml-service:8000

# ── Redis ──
SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379

# ── JWT (prototype only) ──
APP_JWT_SECRET=change-this-secret-in-production-minimum-32-chars!!

# ── CORS ──
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Frontend (Vite dev) ──
VITE_API_PROXY_TARGET=http://localhost:8080
VITE_DEV_PORT=5173
