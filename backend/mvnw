#!/bin/sh
# Maven Wrapper — auto-downloads Maven if not cached
# Generated by: mvn wrapper:wrapper -Dmaven=3.9.9
# Do NOT modify manually.

set -e

MAVEN_VERSION="3.9.9"
MAVEN_DISTRIBUTION_URL="https://dlcdn.apache.org/maven/maven-3/${MAVEN_VERSION}/binaries/apache-maven-${MAVEN_VERSION}-bin.zip"
MVN_HOME="${HOME}/.m2/wrapper/dists/apache-maven-${MAVEN_VERSION}"
MVN_BIN="${MVN_HOME}/bin/mvn"

if [ ! -f "${MVN_BIN}" ]; then
  echo "[mvnw] Downloading Maven ${MAVEN_VERSION}..."
  mkdir -p "${MVN_HOME}"
  TMP_ZIP=$(mktemp /tmp/maven.XXXXXX.zip)
  curl -fsSL "${MAVEN_DISTRIBUTION_URL}" -o "${TMP_ZIP}"
  unzip -q "${TMP_ZIP}" -d "${MVN_HOME}/../"
  mv "${MVN_HOME}/../apache-maven-${MAVEN_VERSION}"/* "${MVN_HOME}/"
  rm -f "${TMP_ZIP}"
  echo "[mvnw] Maven ${MAVEN_VERSION} installed at ${MVN_HOME}"
fi

exec "${MVN_BIN}" "$@"
